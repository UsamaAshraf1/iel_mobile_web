{
  "expo": {
    "name": "IEL Trade",
    "slug": "ielapp",
    "owner": "usama_ashraf1",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/images/app_new_icon.jpg",
    "scheme": "ielnew",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codezbit788.ielnew",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 20190228,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/app_new_icon.jpg",
        "backgroundImage": "./assets/images/Black_colour.jpg",
        "monochromeImage": "./assets/images/app_new_icon.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.codezbit788.ielnew",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-web-browser",
      "expo-file-system",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app_splash_new_icon.png",
          "resizeMode": "contain",
          "imageWidth": 300
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b7d15aa9-e80b-41d0-8c4c-d444b725387e"
      }
    }
  }
}
